use oliststoreanalysis;

desc oliststore;
select * from oliststore;

#1st kpi: WEEKDAY VS WEEKEND PAYMENT STATISTICS

SELECT 
    `Weekend/Weekday` AS day_type,
    CONCAT('R$', FORMAT(SUM(`olist_order_payments_dataset.payment_value`), 2)) AS total_payments
FROM oliststore
GROUP BY day_type;


# 2nd kpi: Number of Orders with review score 5 and payment type as credit card

  
SELECT COUNT(DISTINCT `olist_orders_dataset.order_id`) AS num_orders
FROM oliststore
WHERE `olist_order_reviews_dataset.review_score` = 5
  AND TRIM(LOWER(`olist_order_payments_dataset.payment_type`)) = 'credit_card';
  
  
#3rd kpi: Average number of days taken for order_delivered_customer_date for pet_shop

SELECT AVG(`Delivery Days`) AS avg_delivery_days
FROM oliststore
WHERE `olist_products_dataset.product_category_name` = 'pet_shop';


#4th kpi: Average price and payment values from customers of sao paulo city

SELECT 
    CONCAT('R$', FORMAT(AVG(`olist_order_items_dataset.price`), 2)) AS avg_price,
    CONCAT('R$', FORMAT(AVG(`olist_order_payments_dataset.payment_value`), 2)) AS avg_payment
FROM oliststore
WHERE customer_city = 'sao paulo';


#5th kpi: Relationship between shipping days (order_delivered_customer_date - order_purchase_timestamp) Vs review scores.

SELECT 
    `olist_order_reviews_dataset.review_score` AS review_score,
    ROUND(AVG(`Delivery Days`), 2) AS avg_shipping_days
FROM oliststore
WHERE `olist_orders_dataset.order_status` = 'delivered'
GROUP BY review_score
ORDER BY review_score DESC;
